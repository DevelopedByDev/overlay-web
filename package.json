{
  "name": "getoverlay-landing",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "convex:push:prod": "convex deploy -y",
    "convex:push:dev": "convex dev --once --env-file .env.local",
    "convex:push:all": "npm run convex:push:prod && npm run convex:push:dev",
    "convex:deploy": "npm run convex:push:prod",
    "convex:deploy:dev": "npm run convex:push:dev",
    "convex:deploy:all": "npm run convex:push:all",
    "dev": "next dev",
    "dev:with-convex": "npm run convex:push:dev && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "video:studio": "npx remotion studio src/remotion/index.ts",
    "video:render:launch": "mkdir -p renders && npx remotion render src/remotion/index.ts overlay-launch-video renders/overlay-launch-video.mp4",
    "test:auth:env": "node --experimental-strip-types scripts/auth-dev-env-check.ts",
    "test:auth:convex": "node --experimental-strip-types scripts/auth-convex-debug.ts",
    "test:auth:cookie": "node --experimental-strip-types scripts/auth-cookie-inspect.ts",
    "test:auth:refresh": "node --experimental-strip-types scripts/auth-refresh-check.ts",
    "test:automations": "node --test --experimental-strip-types src/lib/automations.test.ts",
    "test:billing": "node --test --experimental-strip-types src/lib/billing-pricing.test.ts",
    "test:chat-history": "node --test --experimental-strip-types src/lib/chat-history-persistence.test.ts",
    "test:file-text-search": "node --test --experimental-strip-types src/lib/file-text-search.test.ts",
    "test:daytona:smoke": "node --env-file=.env.local --experimental-strip-types scripts/daytona-tool-smoke.ts",
    "test:daytona:reconcile:smoke": "node --env-file=.env.local --experimental-strip-types scripts/daytona-reconcile-smoke.ts",
    "test:unified-tools": "node --experimental-strip-types scripts/unified-tools-sanity.ts",
    "convex:audit:storage": "node --experimental-strip-types scripts/convex-storage-audit.ts",
    "convex:backfill:storage": "node --experimental-strip-types scripts/convex-storage-backfill.ts",
    "convex:reindex:knowledge": "node --experimental-strip-types scripts/convex-knowledge-reindex.ts",
    "test:jwt": "node --env-file=../overlay-desktop/.env.local --experimental-strip-types scripts/smoke-jwt.ts",
    "test:r2:connectivity": "node --env-file=.env.local --experimental-strip-types scripts/smoke-r2-connectivity.ts",
    "test:r2:presign": "node --env-file=.env.local --experimental-strip-types scripts/smoke-r2-presign.ts",
    "test:r2:budget": "node --env-file=.env.local --experimental-strip-types scripts/smoke-r2-budget.ts",
    "test:vault:smoke": "node --env-file=../overlay-desktop/.env.local --experimental-strip-types scripts/smoke-vault.ts",
    "stripe:setup:variable-pricing": "node --env-file=.env.local --experimental-strip-types scripts/stripe-variable-pricing-setup.ts",
    "billing:migrate:staging": "node --env-file=.env.local --experimental-strip-types scripts/variable-pricing-migration.ts",
    "billing:audit:stripe": "node --experimental-strip-types scripts/stripe-dynamic-pricing-audit.ts",
    "test:auth:native-validation": "node --test --experimental-strip-types src/lib/native-auth-validation.test.ts src/lib/native-refresh-rate-limit.test.ts",
    "test:auth:native-smoke": "node --env-file=.env.local --experimental-strip-types scripts/native-auth-security-smoke.ts"
  },
