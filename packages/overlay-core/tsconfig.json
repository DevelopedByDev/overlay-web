{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["es2022", "dom"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "paths": {
      "@overlay/plugin-sdk": ["../overlay-plugin-sdk/src/index.ts"],
      "@overlay/plugin-sdk/server": ["../overlay-plugin-sdk/src/server.ts"],
      "@overlay/plugin-sdk/client": ["../overlay-plugin-sdk/src/client.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
