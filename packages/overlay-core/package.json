{
  "name": "@overlay/core",
  "version": "0.0.1",
  "private": true,
  "sideEffects": false,
  "description": "Overlay core business logic interfaces and provider contracts.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@overlay/plugin-sdk": "0.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5"
  }
}
