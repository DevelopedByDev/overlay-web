{
  "name": "@overlay/core",
  "version": "0.0.1",
  "private": true,
  "sideEffects": false,
  "description": "Overlay core business logic interfaces and provider contracts.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "docs:typedoc": "typedoc --options typedoc.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@overlay/plugin-sdk": "0.0.1",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.7",
    "tsup": "^8.5.0",
    "typedoc": "^0.28.19",
    "typescript": "^5"
  }
}
