{
  "name": "create-overlay-app",
  "version": "0.0.1",
  "description": "Scaffold an Overlay instance with interactive setup",
  "bin": {
    "create-overlay-app": "./dist/cli.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "chalk": "^5.5.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5",
    "@types/node": "^20"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
