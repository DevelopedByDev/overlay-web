{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://www.getoverlay.io",
          "https://getoverlay.io",
          "http://localhost:3000",
          "http://localhost:3001"
        ],
        "methods": ["PUT", "GET", "HEAD"],
        "headers": ["*"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
