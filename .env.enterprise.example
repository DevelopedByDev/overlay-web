# Self-hosted Overlay enterprise defaults. Copy to .env.enterprise for Docker Compose.

OVERLAY_DEPLOYMENT_MODE=self-hosted
OVERLAY_DOMAIN=http://localhost:3000
TRUST_PROXY_HEADERS=false

OVERLAY_DATABASE_PROVIDER=postgres
DATABASE_URL=postgres://overlay:overlay_postgres_password@postgres:5432/overlay
POSTGRES_PASSWORD=overlay_postgres_password
OVERLAY_DB_MIGRATION_MODE=manual
OVERLAY_ADMIN_EMAIL=admin@example.com

OVERLAY_AUTH_PROVIDER=keycloak
KEYCLOAK_ISSUER=http://keycloak:8080/realms/overlay
KEYCLOAK_CLIENT_ID=overlay-web
KEYCLOAK_CLIENT_SECRET=change_me_keycloak_client_secret
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin

OVERLAY_STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_NAME=overlay
MINIO_ROOT_USER=overlay_minio
MINIO_ROOT_PASSWORD=overlay_minio_password
MINIO_ACCESS_KEY_ID=overlay_minio
MINIO_SECRET_ACCESS_KEY=overlay_minio_password

OVERLAY_AI_GATEWAY=ollama
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_DEFAULT_MODEL=llama3.1

OVERLAY_BILLING_PROVIDER=disabled
OVERLAY_CACHE_PROVIDER=redis
REDIS_URL=redis://redis:6379
MEILI_MASTER_KEY=change_me_meilisearch_master_key

SESSION_SECRET=change_me_session_secret_at_least_32_chars
SESSION_TRANSFER_KEY=change_me_session_transfer_key_32_chars
SESSION_COOKIE_ENCRYPTION_KEY=change_me_cookie_encryption_key_32_chars
INTERNAL_API_SECRET=change_me_internal_api_secret
INTERNAL_SERVICE_AUTH_SECRET=change_me_internal_service_auth_secret
PROVIDER_KEYS_SECRET=change_me_provider_keys_secret
HOOKS_TOKEN_SALT=change_me_hooks_token_salt

NEXT_PUBLIC_APP_URL=http://localhost:3000
