{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/server/*": [
        "./src/server/*"
      ],
      "@/shared/*": [
        "./src/shared/*"
      ],
      "@/features/*": [
        "./src/features/*"
      ],
      "@overlay/api-client": [
        "./packages/overlay-api-client/src/index.ts"
      ],
      "@overlay/api-client/*": [
        "./packages/overlay-api-client/src/*"
      ],
      "@overlay/agent-runtime": [
        "./packages/overlay-agent-runtime/src/index.ts"
      ],
      "@overlay/agent-runtime/*": [
        "./packages/overlay-agent-runtime/src/*"
      ],
      "@overlay/app-core": [
        "./packages/overlay-app-core/src/index.ts"
      ],
      "@overlay/app-core/*": [
        "./packages/overlay-app-core/src/*"
      ],
      "@overlay/auth-contracts": [
        "./packages/overlay-auth-contracts/src/index.ts"
      ],
      "@overlay/auth-contracts/*": [
        "./packages/overlay-auth-contracts/src/*"
      ],
      "@overlay/chat-core": [
        "./packages/overlay-chat-core/src/index.ts"
      ],
      "@overlay/chat-core/*": [
        "./packages/overlay-chat-core/src/*"
      ],
      "@overlay/chat-react": [
        "./packages/overlay-chat-react/src/index.ts"
      ],
      "@overlay/chat-react/draft-review-modal": [
        "./packages/overlay-chat-react/src/components/DraftReviewModal.tsx"
      ],
      "@overlay/chat-react/sources-panel": [
        "./packages/overlay-chat-react/src/components/SourcesPanel.tsx"
      ],
      "@overlay/chat-react/*": [
        "./packages/overlay-chat-react/src/*"
      ],
      "@overlay/llm-gateway": [
        "./packages/overlay-llm-gateway/src/index.ts"
      ],
      "@overlay/llm-gateway/*": [
        "./packages/overlay-llm-gateway/src/*"
      ],
      "@overlay/modules-react": [
        "./packages/overlay-modules-react/src/index.ts"
      ],
      "@overlay/modules-react/*": [
        "./packages/overlay-modules-react/src/*"
      ],
      "@overlay/storage-contracts": [
        "./packages/overlay-storage-contracts/src/index.ts"
      ],
      "@overlay/storage-contracts/*": [
        "./packages/overlay-storage-contracts/src/*"
      ],
      "@overlay/tools-core": [
        "./packages/overlay-tools-core/src/index.ts"
      ],
      "@overlay/tools-core/*": [
        "./packages/overlay-tools-core/src/*"
      ],
      "@overlay/ui": [
        "./packages/overlay-ui/src/index.ts"
      ],
      "@overlay/ui/*": [
        "./packages/overlay-ui/src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "archives",
    "overlay-chrome",
    "overlay-desktop",
    "overlay-mobile",
    "workers",
    "scripts"
  ]
}
