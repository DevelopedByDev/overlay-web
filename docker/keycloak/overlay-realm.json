{
  "realm": "overlay",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "clients": [
    {
      "clientId": "overlay-web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "change_me_keycloak_client_secret",
      "redirectUris": [
        "http://localhost:3000/api/auth/callback"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true
    }
  ],
  "roles": {
    "realm": [
      { "name": "superadmin" },
      { "name": "admin" },
      { "name": "user" }
    ]
  },
  "users": [
    {
      "username": "admin@example.com",
      "email": "admin@example.com",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "change_me_admin_password",
          "temporary": true
        }
      ],
      "realmRoles": ["superadmin"]
    }
  ]
}
